<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moon_bg_dark">

    <!-- Contenido principal con scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 MOON TV"
                        android:textColor="@color/moon_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/moon_text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_favorites"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_favorite_outline"
                    android:tint="@color/moon_purple_light"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Favoritos"/>

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/moon_text_secondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ajustes"/>
            </LinearLayout>

            <!-- ── SEARCH ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_search_bix"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp"/>

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Buscar"
                    android:textColor="@color/moon_text_primary"
                    android:textColorHint="@color/moon_text_secondary"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:singleLine="true"/>
            </LinearLayout>

            <!-- ── EXPLORAR ───────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPLORAR"
                android:textColor="@color/moon_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explorar por categoría"
                android:textColor="@color/moon_text_secondary"
                android:textSize="12sp"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="16dp"/>

            <!-- Botones grandes de categoría -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="28dp">

                <Button
                    android:id="@+id/btn_cat_movies"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="🎬 PELÍCULAS"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:backgroundTint="@color/moon_purple"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btn_cat_series"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="📺 SERIES"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:backgroundTint="@color/moon_purple"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btn_cat_tv"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="📡 TV EN VIVO"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:backgroundTint="@color/moon_purple"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>


            <!-- ── EVENTOS DEL DÍA ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏆 EVENTOS DEL DÍA"
                    android:textColor="@color/moon_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todos →"
                    android:textColor="@color/moon_purple_light"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="28dp"/>

            <!-- ── LO MÁS POPULAR ────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LO MÁS POPULAR"
                android:textColor="@color/moon_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top de canales más vistos"
                android:textColor="@color/moon_text_secondary"
                android:textSize="12sp"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="12dp"/>

            <!-- Carrusel de destacados -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_featured"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:layout_marginBottom="28dp"/>

            <!-- ── TV EN VIVO - CANALES ───────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📡 TV EN VIVO"
                    android:textColor="@color/moon_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todos →"
                    android:textColor="@color/moon_purple_light"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="28dp"/>

            <!-- ── EXPLORAR POR GÉNERO ────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPLORAR POR GÉNERO"
                android:textColor="@color/moon_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="28dp"/>

            <!-- ── PELÍCULAS ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎬 PELÍCULAS"
                    android:textColor="@color/moon_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver más →"
                    android:textColor="@color/moon_purple_light"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_movies"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="28dp"/>

            <!-- ── SERIES ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎭 SERIES"
                    android:textColor="@color/moon_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver más →"
                    android:textColor="@color/moon_purple_light"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_series"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp"/>

            <!-- Loading / Error -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="24dp"
                android:indeterminateTint="@color/moon_purple"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/moon_error"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BARRA DE NAVEGACIÓN INFERIOR ──────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/moon_bg_card"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
