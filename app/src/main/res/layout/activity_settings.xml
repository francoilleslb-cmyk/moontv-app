<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/moon_bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/moon_bg_card">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/moon_text_primary"
            android:contentDescription="Volver" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ Ajustes"
            android:textColor="@color/moon_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Panel Admin ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ADMINISTRACIÓN" android:textColor="@color/moon_purple"
                android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <Button android:id="@+id/btn_admin_panel"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="🎛️  Abrir Panel de Canales"
                android:backgroundTint="@color/moon_purple"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:layout_marginBottom="4dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Abre el panel admin en el navegador para agregar y editar canales."
                android:textColor="@color/moon_text_secondary" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="20dp" android:background="#2A2A3E"/>

            <!-- ── Backend ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SERVIDOR BACKEND" android:textColor="@color/moon_purple"
                android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="URL de tu backend en Render:"
                android:textColor="@color/moon_text_secondary" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/et_backend_url"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_input" android:textColor="@color/moon_text_primary"
                android:textColorHint="@color/moon_text_secondary"
                android:hint="https://tu-app.onrender.com/"
                android:inputType="textUri" android:singleLine="true" android:padding="14dp"
                android:textSize="13sp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="12dp">
                <Button android:id="@+id/btn_save_url"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="💾 Guardar" android:backgroundTint="@color/moon_purple"
                    android:textColor="@android:color/white" android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_reset_url"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content" android:layout_height="44dp"
                    android:text="Restablecer" android:textColor="@color/moon_text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="20dp" android:background="#2A2A3E"/>

            <!-- ── Reproducción ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="REPRODUCCIÓN" android:textColor="@color/moon_purple"
                android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Reproducción automática"
                    android:textColor="@color/moon_text_primary" android:textSize="15sp"/>
                <Switch android:id="@+id/switch_autoplay"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="@color/moon_purple" android:trackTint="@color/moon_bg_card2"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="20dp" android:background="#2A2A3E"/>

            <!-- ── Favoritos ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FAVORITOS" android:textColor="@color/moon_purple"
                android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tv_fav_count" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/moon_text_secondary" android:textSize="14sp"/>
                <Button android:id="@+id/btn_clear_favorites"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="Borrar todo" android:textColor="@color/moon_error"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Versión -->
            <TextView android:id="@+id/tv_app_version"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="32dp" android:layout_marginBottom="16dp"
                android:textColor="@color/moon_text_secondary" android:textSize="12sp"
                android:gravity="center"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
