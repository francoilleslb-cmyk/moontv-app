<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moon_bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="72sp"
            android:layout_marginTop="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moon TV"
            android:textColor="@color/moon_text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicia sesión para continuar"
            android:textColor="@color/moon_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="40dp" />

        <!-- Error -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_error"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo electrónico"
            android:textColor="@color/moon_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/moon_text_primary"
            android:textColorHint="@color/moon_text_secondary"
            android:hint="usuario@correo.com"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textColor="@color/moon_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/moon_text_primary"
            android:textColorHint="@color/moon_text_secondary"
            android:hint="••••••••"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:layout_marginBottom="28dp" />

        <!-- Botón Login -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Iniciar sesión"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/moon_purple"
            android:textColor="@android:color/white" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <!-- Ir a Registro -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta?  "
                android:textColor="@color/moon_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_go_register"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regístrate"
                android:textColor="@color/moon_purple_light"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
